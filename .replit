modules = ["nodejs-20"]

# This tells Replit exactly what to do when you hit the 'Run' button
run = "npm start"

# This points to your main entry file as required by the brief
entrypoint = "server.js"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[agent]
expertMode = true
