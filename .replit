modules = ["nodejs-20"]

# This tells Replit exactly what to do when you hit the 'Run' button
run = "npm start"

# This points to your main entry file as required by the brief
entrypoint = "server.js"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8090
externalPort = 3000

[[ports]]
localPort = 8091
externalPort = 3001

[[ports]]
localPort = 8092
externalPort = 3002

[[ports]]
localPort = 8095
externalPort = 3003

[agent]
expertMode = true

[userenv]

[userenv.shared]
PORT = "8080"
DATABASE_URL = "postgresql://postgres:password@helium/heliumdb?sslmode=disable"

[nix]
packages = ["killall"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "webview"
